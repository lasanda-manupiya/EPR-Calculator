# Copy to .env and fill in from Supabase → Project Settings → API.
# If these are missing the app falls back to browser localStorage (single-user, no cloud).
VITE_SUPABASE_URL=https://clzwkajgzgkhweyurrmr.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Email 2FA on login: set to "on" to require an emailed 6-digit code at sign-in.
# ONLY enable this after custom SMTP is configured — the built-in email service
# (2 emails/hour) will lock users out otherwise. Leave unset/off until then.
VITE_LOGIN_OTP=off

# NEVER commit real values. .env is git-ignored.
# The service_role key is NOT needed by this app and must never ship to the client.
